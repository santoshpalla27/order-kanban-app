{
  "expo": {
    "name": "Kanban",
    "slug": "kanban-mobile",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "android": {
      "package": "com.kanbanmobile",
      "softwareKeyboardLayoutMode": "pan"
    },
    "ios": {
      "bundleIdentifier": "com.kanbanmobile",
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Used to upload photos as attachments",
        "NSPhotoLibraryAddUsageDescription": "Used to save downloaded files"
      }
    },
    "plugins": [
      ["expo-image-picker", { "photosPermission": "Used to upload photos as attachments" }],
      ["expo-document-picker", { "iCloudContainerEnvironment": "Production" }]
    ],
    "newArchEnabled": true
  }
}
