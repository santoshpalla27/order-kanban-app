# ── Server ────────────────────────────────────────────────────────────────────
# Port exposed by the backend (inside the container, not the host port)
PORT=8080

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret

# Comma-separated list of allowed frontend origins (no trailing slash)
# Example: https://app.example.com,https://www.example.com
CORS_ORIGINS=http://localhost:3000

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
R2_BUCKET=your-bucket-name
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY=your-r2-access-key-id
R2_SECRET_KEY=your-r2-secret-access-key
# Format: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# ── Frontend ──────────────────────────────────────────────────────────────────
# Full URL to the backend API (baked into the frontend at build time by Vite)
VITE_API_URL=http://localhost:8080/api

# Host port to expose the frontend on
FRONTEND_PORT=3000
