# ── Domain ────────────────────────────────────────────────────────────────────
# Base domain — app runs at app.<DOMAIN>, dashboard at traefik.<DOMAIN>
DOMAIN=santoshdevops.cloud

# Email used by Let's Encrypt for expiry notifications
ACME_EMAIL=you@example.com

# Traefik dashboard basic-auth credentials (user:bcrypt-hashed-password)
# Generate with: echo $(htpasswd -nB admin) | sed -e s/\\$/\\$\\$/g
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$replace_with_real_hash

# ── Server ────────────────────────────────────────────────────────────────────
# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret

# Allowed frontend origins — must match app.<DOMAIN>
CORS_ORIGINS=https://app.santoshdevops.cloud

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
R2_BUCKET=your-bucket-name
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY=your-r2-access-key-id
R2_SECRET_KEY=your-r2-secret-access-key
# Format: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# ── Frontend ──────────────────────────────────────────────────────────────────
# Full public URL to the backend API — baked into the JS bundle at build time
VITE_API_URL=https://app.santoshdevops.cloud/api
