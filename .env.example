# ── Let's Encrypt ─────────────────────────────────────────────────────────────
ACME_EMAIL=you@example.com

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=kanban
POSTGRES_USER=kanban
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=change-me-strong-password

# ── Domains ───────────────────────────────────────────────────────────────────
DOMAIN=app.yourdomain.com
MONITOR_DOMAIN=m.yourdomain.com
CORS_ORIGINS=https://app.yourdomain.com

# ── Server ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret
# Set to "json" in production for structured logging; omit for human-readable text in dev
LOG_FORMAT=json

# ── Monitor — basic auth ──────────────────────────────────────────────────────
# Generate with: htpasswd -nb admin yourpassword
# IMPORTANT: escape every $ as $$ in .env files
# Example: ADMIN_AUTH=admin:$$2y$$05$$xyz...
ADMIN_AUTH=admin:hashed-password-here

# ── Cloudflare DNS challenge (for Let's Encrypt with Cloudflare proxy) ─────────
# Create at: Cloudflare Dashboard → My Profile → API Tokens → Create Token
# Required permissions: Zone → DNS → Edit (scoped to your domain)
CF_API_TOKEN=your-cloudflare-api-token

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
R2_BUCKET=your-bucket-name
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY=your-r2-access-key-id
R2_SECRET_KEY=your-r2-secret-access-key
# Format: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# ── Expo push notifications ───────────────────────────────────────────────────
EXPO_ACCESS_TOKEN=your-expo-access-token
