meta {
  name: Get Me (Authenticated)
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/auth/me
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });

  test("returns user object", function() {
    expect(res.body.id).to.be.a("number");
    expect(res.body.email).to.be.a("string");
    expect(res.body.role).to.be.an("object");
    expect(res.body.role.name).to.be.a("string");
  });

  test("does not return password", function() {
    expect(res.body.password).to.be.undefined;
  });
}
