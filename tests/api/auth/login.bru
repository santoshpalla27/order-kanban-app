meta {
  name: Login - Admin
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "{{adminEmail}}",
    "password": "{{adminPassword}}"
  }
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });

  test("returns access_token", function() {
    expect(res.body.access_token).to.be.a("string").and.not.empty;
  });

  test("returns refresh_token", function() {
    expect(res.body.refresh_token).to.be.a("string").and.not.empty;
  });

  test("returns user object with role", function() {
    expect(res.body.user).to.be.an("object");
    expect(res.body.user.role.name).to.equal("admin");
  });

  // Store tokens for subsequent requests
  bru.setVar("accessToken", res.body.access_token);
  bru.setVar("refreshToken", res.body.refresh_token);
  bru.setVar("adminUserId", res.body.user.id);
}
