meta {
  name: Login - Wrong Password (401)
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "{{adminEmail}}",
    "password": "wrongpassword"
  }
}

tests {
  test("status is 401", function() {
    expect(res.status).to.equal(401);
  });

  test("no tokens returned", function() {
    expect(res.body.access_token).to.be.undefined;
  });
}
