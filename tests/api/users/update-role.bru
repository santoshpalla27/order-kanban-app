meta {
  name: Update User Role (Admin only)
  type: http
  seq: 3
}

patch {
  url: {{baseUrl}}/users/{{testUserId}}/role
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "role_id": 3
  }
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });

  test("role is updated to organiser", function() {
    expect(res.body.role.name).to.equal("organiser");
  });
}
