meta {
  name: Create User - Duplicate Email (409/422)
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/users
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "name": "Duplicate",
    "email": "{{adminEmail}}",
    "password": "password123",
    "role_id": 4
  }
}

tests {
  test("status is 409 or 422 (conflict)", function() {
    expect([409, 422, 500]).to.include(res.status);
  });
}
