meta {
  name: RBAC - Login as View Only (setup)
  type: http
  seq: 0
}

post {
  url: {{baseUrl}}/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "{{viewonlyEmail}}",
    "password": "{{viewonlyPassword}}"
  }
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });

  bru.setVar("viewonlyToken", res.body.access_token);
}
