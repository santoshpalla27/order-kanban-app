meta {
  name: RBAC - View Only cannot comment (403)
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/products/{{productId}}/comments
  body: json
  auth: bearer
}

auth:bearer {
  token: {{viewonlyToken}}
}

body:json {
  {
    "message": "Should fail"
  }
}

tests {
  test("view_only cannot comment — 403", function() {
    expect(res.status).to.equal(403);
  });
}
