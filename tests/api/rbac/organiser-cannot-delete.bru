meta {
  name: RBAC - Organiser cannot delete product (403)
  type: http
  seq: 2
}

delete {
  url: {{baseUrl}}/products/{{productId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{organiserToken}}
}

tests {
  test("organiser cannot delete product — 403", function() {
    expect(res.status).to.equal(403);
  });
}
