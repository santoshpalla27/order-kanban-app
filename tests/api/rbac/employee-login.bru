meta {
  name: RBAC - Login as Employee (setup)
  type: http
  seq: 0
}

post {
  url: {{baseUrl}}/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "{{employeeEmail}}",
    "password": "{{employeePassword}}"
  }
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });

  bru.setVar("employeeToken", res.body.access_token);
  bru.setVar("employeeId", res.body.user.id);
}
