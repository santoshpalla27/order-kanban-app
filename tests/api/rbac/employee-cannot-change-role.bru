meta {
  name: RBAC - Employee cannot change roles (403)
  type: http
  seq: 7
}

patch {
  url: {{baseUrl}}/users/{{employeeId}}/role
  body: json
  auth: bearer
}

auth:bearer {
  token: {{employeeToken}}
}

body:json {
  {
    "role_id": 1
  }
}

tests {
  test("employee cannot change role — 403", function() {
    expect(res.status).to.equal(403);
  });
}
