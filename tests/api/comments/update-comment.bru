meta {
  name: Update Comment (Own)
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/comments/{{newCommentId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "message": "Updated comment message"
  }
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });

  test("message is updated", function() {
    expect(res.body.message).to.equal("Updated comment message");
  });
}
