meta {
  name: List Comments for Product
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/products/{{productId}}/comments
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });

  test("returns array of comments", function() {
    expect(res.body).to.be.an("array");
  });

  test("each comment has required fields", function() {
    if (res.body.length > 0) {
      const c = res.body[0];
      expect(c.id).to.be.a("number");
      expect(c.message).to.be.a("string");
      expect(c.user).to.be.an("object");
      expect(c.created_at).to.be.a("string");
    }
  });

  if (res.body && res.body.length > 0) {
    bru.setVar("commentId", res.body[0].id);
  }
}
