meta {
  name: Create Comment
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/products/{{productId}}/comments
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "message": "Test comment from API test suite"
  }
}

tests {
  test("status is 201", function() {
    expect(res.status).to.equal(201);
  });

  test("returns created comment", function() {
    expect(res.body.id).to.be.a("number");
    expect(res.body.message).to.equal("Test comment from API test suite");
    expect(res.body.user).to.be.an("object");
  });

  bru.setVar("newCommentId", res.body.id);
}
