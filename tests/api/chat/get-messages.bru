meta {
  name: Get Chat Messages
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/chat/messages?limit=50
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });

  test("returns paginated structure", function() {
    expect(res.body.data).to.be.an("array");
    expect(res.body).to.have.property("has_more");
  });

  test("each message has required fields", function() {
    if (res.body.data.length > 0) {
      const m = res.body.data[0];
      expect(m.id).to.be.a("number");
      expect(m.message).to.be.a("string");
      expect(m.created_at).to.be.a("string");
    }
  });
}
