meta {
  name: Get Product by ID
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/products/{{productId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });

  test("returns full product with relations", function() {
    expect(res.body.id).to.equal(bru.getVar("productId"));
    expect(res.body.creator).to.be.an("object");
    expect(res.body.attachments).to.be.an("array");
    expect(res.body.comments).to.be.an("array");
  });
}
