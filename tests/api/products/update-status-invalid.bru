meta {
  name: Update Status - Invalid Value (400)
  type: http
  seq: 10
}

patch {
  url: {{baseUrl}}/products/{{newProductId}}/status
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "status": "invalid_status"
  }
}

tests {
  test("status is 400", function() {
    expect(res.status).to.equal(400);
  });
}
