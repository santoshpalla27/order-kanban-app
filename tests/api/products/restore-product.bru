meta {
  name: Restore Product from Trash
  type: http
  seq: 13
}

post {
  url: {{baseUrl}}/products/{{newProductId}}/restore
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });

  test("restored product has no deleted_at", function() {
    expect(res.body.deleted_at).to.be.null;
  });
}
