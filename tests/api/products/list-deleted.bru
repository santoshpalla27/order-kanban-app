meta {
  name: List Deleted Products (Trash)
  type: http
  seq: 12
}

get {
  url: {{baseUrl}}/products/deleted
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });

  test("deleted product appears in trash", function() {
    const found = res.body.data.find(p => p.id === bru.getVar("newProductId"));
    expect(found).to.not.be.undefined;
    expect(found.deleted_at).to.not.be.null;
  });
}
