meta {
  name: Update Product
  type: http
  seq: 8
}

put {
  url: {{baseUrl}}/products/{{newProductId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "customer_name": "Updated Customer Name",
    "customer_phone": "+9876543210",
    "description": "Updated description"
  }
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });

  test("customer_name is updated", function() {
    expect(res.body.customer_name).to.equal("Updated Customer Name");
  });
}
