meta {
  name: Create Product (Admin)
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/products
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "product_id": "PROD-TEST-{{$timestamp}}",
    "customer_name": "Test Customer",
    "customer_phone": "+1234567890",
    "description": "Test product created by API test suite"
  }
}

tests {
  test("status is 201", function() {
    expect(res.status).to.equal(201);
  });

  test("returns created product", function() {
    expect(res.body.id).to.be.a("number");
    expect(res.body.status).to.equal("yet_to_start");
    expect(res.body.customer_name).to.equal("Test Customer");
  });

  // Save the new product id for update/delete tests
  bru.setVar("newProductId", res.body.id);
  bru.setVar("newProductOriginalId", res.body.product_id);
}
