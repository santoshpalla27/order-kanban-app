meta {
  name: Update Product Status
  type: http
  seq: 9
}

patch {
  url: {{baseUrl}}/products/{{newProductId}}/status
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "status": "working"
  }
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });
}
